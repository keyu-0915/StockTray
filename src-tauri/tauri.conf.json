{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StockTray",
  "version": "0.2.8",
  "identifier": "com.stocktray.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "settings",
        "title": "StockTray 设置",
        "url": "index.html#/settings",
        "width": 920,
        "height": 700,
        "visible": false,
        "resizable": true,
        "decorations": true,
        "center": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      },
      {
        "label": "popup",
        "title": "StockTray 行情",
        "url": "index.html#/popup",
        "width": 600,
        "height": 360,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
