{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StockTray",
  "version": "0.2.19",
  "identifier": "com.stocktray.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "settings",
        "title": "StockTray",
        "url": "index.html#/settings",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "visible": false,
        "resizable": true,
        "decorations": false,
        "center": true,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "popup",
        "title": "StockTray 行情",
        "url": "index.html#/popup",
        "width": 600,
        "height": 360,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDMDZCNDgxOTA1OUNGOTQKUldTVXoxbVFnYlFHakRtcDYyLy82d3loRGxFNmJpL3QwM050akhOSUpUQlBCa1BJVzUyZlluSjYK",
      "endpoints": [
        "https://github.com/keyu-0915/StockTray/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
